<section id="events" class="py-16 px-4 scroll-mt-16">
  <div class="max-w-3xl mx-auto">
    <h2 class="text-2xl md:text-3xl font-bold text-center text-gray-800 mb-12">年間イベント</h2>

    <div class="relative">
      <!-- Timeline line -->
      <div class="absolute left-4 md:left-1/2 top-0 bottom-0 w-0.5 bg-primary/30 -translate-x-1/2"></div>

      <% events.each_with_index do |event, i| %>
        <div class="relative mb-8 flex items-start <%= i.even? ? 'md:flex-row-reverse' : '' %>">
          <!-- Dot -->
          <div class="absolute left-4 md:left-1/2 w-4 h-4 bg-primary rounded-full -translate-x-1/2 mt-1.5 z-10 ring-4 ring-white"></div>

          <!-- Content -->
          <div class="ml-10 md:ml-0 md:w-1/2 <%= i.even? ? 'md:pl-8' : 'md:pr-8 md:text-right' %>">
            <div class="bg-white rounded-lg shadow-md p-4">
              <span class="inline-block bg-primary text-white text-sm px-3 py-1 rounded-full mb-2">
                <%= event.month %>月
              </span>
              <h3 class="font-bold text-gray-800"><%= event.title %></h3>
              <% if event.description.present? %>
                <p class="text-sm text-gray-600 mt-1"><%= event.description %></p>
              <% end %>
            </div>
          </div>
        </div>
      <% end %>
    </div>
  </div>
</section>
