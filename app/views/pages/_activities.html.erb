<section id="activities" class="py-16 px-4 bg-gray-50 scroll-mt-16">
  <div class="max-w-4xl mx-auto">
    <h2 class="text-2xl md:text-3xl font-bold text-center text-gray-800 mb-8">活動情報</h2>
    <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
      <div class="bg-white rounded-lg shadow-md p-6">
        <h3 class="font-bold text-lg text-primary mb-3">練習時間</h3>
        <p class="text-gray-700"><%= settings["practice_times"] %></p>
      </div>
      <div class="bg-white rounded-lg shadow-md p-6">
        <h3 class="font-bold text-lg text-primary mb-3">練習場所</h3>
        <p class="text-gray-700"><%= settings["practice_location"] %></p>
      </div>
      <div class="bg-white rounded-lg shadow-md p-6">
        <h3 class="font-bold text-lg text-primary mb-3">部員数</h3>
        <p class="text-gray-700"><%= settings["member_count"] %></p>
      </div>
      <div class="bg-white rounded-lg shadow-md p-6">
        <h3 class="font-bold text-lg text-primary mb-3">対抗戦</h3>
        <p class="text-gray-700"><%= settings["competitive_info"] %></p>
      </div>
    </div>
  </div>
</section>
