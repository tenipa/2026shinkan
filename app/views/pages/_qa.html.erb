<section id="qa" class="py-16 px-4 bg-gray-50 scroll-mt-16">
  <div class="max-w-3xl mx-auto">
    <h2 class="text-2xl md:text-3xl font-bold text-center text-gray-800 mb-8">Q&A</h2>

    <div class="space-y-4">
      <% qa_items.each do |qa| %>
        <div class="bg-white rounded-lg shadow-md overflow-hidden" data-controller="accordion">
          <button class="w-full px-6 py-4 text-left flex items-center justify-between hover:bg-gray-50 transition"
                  data-action="click->accordion#toggle">
            <span class="font-medium text-gray-800">
              <span class="text-primary font-bold mr-2">Q.</span>
              <%= qa.question %>
            </span>
            <svg class="w-5 h-5 text-gray-500 transition-transform" data-accordion-target="icon" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"/>
            </svg>
          </button>
          <div class="hidden px-6 pb-4" data-accordion-target="content">
            <p class="text-gray-700">
              <span class="text-accent font-bold mr-2">A.</span>
              <%= qa.answer %>
            </p>
          </div>
        </div>
      <% end %>
    </div>
  </div>
</section>
