<h1 class="text-2xl font-bold mb-6">ダッシュボード</h1>

<div class="grid grid-cols-1 md:grid-cols-3 gap-6">
  <div class="bg-white rounded shadow p-6">
    <h2 class="text-lg font-semibold text-gray-700">イベント</h2>
    <p class="text-3xl font-bold mt-2"><%= Event.count %></p>
    <%= link_to "管理する →", admin_events_path, class: "text-blue-600 text-sm mt-2 inline-block" %>
  </div>
  <div class="bg-white rounded shadow p-6">
    <h2 class="text-lg font-semibold text-gray-700">Q&A</h2>
    <p class="text-3xl font-bold mt-2"><%= QaItem.count %></p>
    <%= link_to "管理する →", admin_qa_items_path, class: "text-blue-600 text-sm mt-2 inline-block" %>
  </div>
  <div class="bg-white rounded shadow p-6">
    <h2 class="text-lg font-semibold text-gray-700">サイト設定</h2>
    <p class="text-sm text-gray-500 mt-2">タイトル、SNSリンク等</p>
    <%= link_to "編集する →", edit_admin_site_settings_path, class: "text-blue-600 text-sm mt-2 inline-block" %>
  </div>
</div>
