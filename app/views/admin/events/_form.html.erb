<%= form_with model: [:admin, event], class: "bg-white shadow rounded p-6 space-y-4" do |f| %>
  <% if event.errors.any? %>
    <div class="p-3 bg-red-100 text-red-800 rounded">
      <ul>
        <% event.errors.full_messages.each do |msg| %>
          <li><%= msg %></li>
        <% end %>
      </ul>
    </div>
  <% end %>

  <div>
    <%= f.label :title, "タイトル", class: "block text-sm font-medium text-gray-700 mb-1" %>
    <%= f.text_field :title, class: "w-full border border-gray-300 rounded px-3 py-2" %>
  </div>

  <div>
    <%= f.label :month, "月", class: "block text-sm font-medium text-gray-700 mb-1" %>
    <%= f.select :month, (1..12).map { |m| ["#{m}月", m] }, {}, class: "border border-gray-300 rounded px-3 py-2" %>
  </div>

  <div>
    <%= f.label :description, "説明", class: "block text-sm font-medium text-gray-700 mb-1" %>
    <%= f.text_area :description, rows: 3, class: "w-full border border-gray-300 rounded px-3 py-2" %>
  </div>

  <div>
    <%= f.label :position, "表示順", class: "block text-sm font-medium text-gray-700 mb-1" %>
    <%= f.number_field :position, class: "border border-gray-300 rounded px-3 py-2" %>
  </div>

  <div>
    <%= f.submit class: "bg-blue-600 text-white px-6 py-2 rounded hover:bg-blue-700 cursor-pointer" %>
  </div>
<% end %>
