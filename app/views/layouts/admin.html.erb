<!DOCTYPE html>
<html>
<head>
  <title>管理画面 - sinkan2026</title>
  <meta name="viewport" content="width=device-width,initial-scale=1">
  <%= csrf_meta_tags %>
  <%= csp_meta_tag %>
  <%= stylesheet_link_tag :app, "data-turbo-track": "reload" %>
  <%= javascript_importmap_tags %>
</head>
<body class="bg-gray-100 min-h-screen">
  <% if current_admin %>
    <div class="flex min-h-screen">
      <!-- Sidebar -->
      <nav class="w-64 bg-gray-800 text-white flex-shrink-0">
        <div class="p-4">
          <h1 class="text-lg font-bold">管理画面</h1>
        </div>
        <ul class="mt-4">
          <li>
            <%= link_to "ダッシュボード", admin_dashboard_path, class: "block px-4 py-2 hover:bg-gray-700" %>
          </li>
          <li>
            <%= link_to "サイト設定", edit_admin_site_settings_path, class: "block px-4 py-2 hover:bg-gray-700" %>
          </li>
          <li>
            <%= link_to "イベント", admin_events_path, class: "block px-4 py-2 hover:bg-gray-700" %>
          </li>
          <li>
            <%= link_to "Q&A", admin_qa_items_path, class: "block px-4 py-2 hover:bg-gray-700" %>
          </li>
          <li class="mt-4 border-t border-gray-700 pt-4">
            <%= link_to "サイトを見る", root_path, class: "block px-4 py-2 hover:bg-gray-700", target: "_blank" %>
          </li>
          <li>
            <%= button_to "ログアウト", admin_logout_path, method: :delete, class: "block w-full text-left px-4 py-2 hover:bg-gray-700 text-red-300" %>
          </li>
        </ul>
      </nav>

      <!-- Main content -->
      <main class="flex-1 p-8">
        <% if notice %>
          <div class="mb-4 p-3 bg-green-100 text-green-800 rounded"><%= notice %></div>
        <% end %>
        <% if alert %>
          <div class="mb-4 p-3 bg-red-100 text-red-800 rounded"><%= alert %></div>
        <% end %>
        <%= yield %>
      </main>
    </div>
  <% else %>
    <main class="flex items-center justify-center min-h-screen">
      <% if alert %>
        <div class="mb-4 p-3 bg-red-100 text-red-800 rounded"><%= alert %></div>
      <% end %>
      <%= yield %>
    </main>
  <% end %>
</body>
</html>
